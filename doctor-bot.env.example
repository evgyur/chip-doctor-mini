# Copy to doctor-bot.env (e.g. ~/.openclaw/doctor-bot.env) and fill in. chmod 600.
# Get token: Telegram @BotFather → /newbot → copy token.
# Get your ID: message @userinfobot or see bot reply on /start.

DOCTOR_BOT_TOKEN=123456789:ABCdef...
DOCTOR_BOT_ALLOWED_IDS=123456789

# Optional: PATH for openclaw (macOS Homebrew example; leave empty to use system PATH)
# DOCTOR_BOT_PATH=/opt/homebrew/opt/node@22/bin:/opt/homebrew/bin:/usr/bin:/bin
